// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  password     String
  name         String?
  roleId       Int?
  role         Role?    @relation(fields: [roleId], references: [id])
  email        String?
  mobile       String?
  status       String   @default("active") // active, inactive
  createdAt    DateTime @default(now())
}

model Role {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  permissions String?  // JSON string of permissions
  users       User[]
  createdAt   DateTime @default(now())
}

model Blog {
  id           Int      @id @default(autoincrement())
  title        String
  slug         String?  @unique
  content      String
  image        String?
  status       String   @default("published") // draft, published
  metaTitle    String?
  metaDesc     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Employee {
  id        Int      @id @default(autoincrement())
  name      String
  role      String
  image     String?
  priority  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SiteContent {
  id        String   @id // e.g., 'main-video', 'popup-image', 'testimonial-desktop'
  type      String   // e.g., 'text', 'image', 'video'
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Service {
  id             Int      @id @default(autoincrement())
  type           String   // e.g., 'Turnkey solutions', 'Interior fit-out'
  name           String
  subServices    String?  // JSON or comma-separated
  image          String?
  description    String?
  recentProject  String?
  ongoingProject String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Enquiry {
  id        Int      @id @default(autoincrement())
  type      String   // Contact, Careers, Enquiry, Schedule Visit, Joint Venture
  name      String
  email     String
  mobile    String?
  subject   String?
  message   String?
  status    String   @default("new") // new, read, resolved
  createdAt DateTime @default(now())
}

model SeoConfig {
  id          Int      @id @default(autoincrement())
  page        String   @unique // e.g., 'home', 'about', 'services'
  metaTitle   String
  metaDesc    String?
  status      String   @default("active")
  updatedAt   DateTime @updatedAt
}

model ClientLogo {
  id        Int      @id @default(autoincrement())
  image     String
  category  String   @default("corporate") // 'corporate' or 'ongoing'
  createdAt DateTime @default(now())
}

model CareerApplication {
  id          Int      @id @default(autoincrement())
  fullName    String
  email       String
  phone       String
  position    String
  experience  String?
  location    String?
  linkedin    String?
  coverLetter String?
  resumePath  String
  resumeName  String?
  status      String   @default("new") // new, screening, interview, offered, rejected, hired
  notes       String?
  viewedAt    DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
